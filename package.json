{
  "name": "@mvuljevas/agents",
  "version": "0.21.0",
  "description": "Reusable AGENTS templates, workflows, and guided AI tooling setup.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agents": "./cli/agents.js"
  },
  "files": [
    "AGENTS.md",
    "LICENSE",
    "README.md",
    "VERSION",
    "cli/",
    "docs/",
    ".githooks/",
    "presets/",
    "scripts/",
    "templates/",
    ".agents.env.example",
    ".aiignore",
    ".rgignore",
    "repomix.config.json"
  ],
  "scripts": {
    "agents": "node cli/agents.js --help",
    "agents:init": "node cli/agents.js --init",
    "agents:setup": "node cli/agents.js --setup",
    "agents:doctor": "node cli/agents.js --doctor",
    "agents:dashboard": "node cli/agents.js --dashboard",
    "agents:dev": "node cli/agents.js --run -- npm run dev",
    "test": "node cli/agents.js --doctor && node cli/agents.js --setup --dry-run && node cli/agents.js --mcp-create --dry-run && node cli/agents.js --suggest --idea \"React PWA\" --issue --dry-run"
  },
  "engines": {
    "node": ">=20"
  }
}
