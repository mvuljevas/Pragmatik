{
  "manifest_version": 3,
  "name": "Chrome Extension Vanilla",
  "version": "0.11.0",
  "description": "A vanilla Chrome extension starter with AGENTS and lean-context workflow.",
  "icons": {},
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Chrome Extension Vanilla"
  }
}
