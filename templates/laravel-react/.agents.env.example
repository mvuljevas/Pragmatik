# Local non-secret agent experiment flags.
# Copy to `.agents.env` to run baseline vs lean-context comparisons.

# Allowed values: baseline, lean-context
AGENTS_CONTEXT_MODE=lean-context

# Optional labels for comparing equivalent runs across cloned repositories.
AGENTS_EXPERIMENT_ID=
AGENTS_EXPERIMENT_RUN=
AGENTS_EXPERIMENT_TASK=

# Allowed values: ask, on, off
AGENTS_CONTEXT7=ask
AGENTS_REPOMIX=ask
AGENTS_TOKSCALE=ask
AGENTS_TOKLESS=ask
AGENTS_MCP=ask
AGENTS_DASHBOARD=on
AGENTS_DASHBOARD_AUTOSTART=on
AGENTS_DASHBOARD_WRAPPER_ONLY=on

# Allowed values: off, dry-run, on
# `on` uploads usage data to the configured external Tokscale account.
# Use `on` only when the user wants external submission.
AGENTS_TOKSCALE_SUBMIT=dry-run

# Allowed values: on, off
AGENTS_AUTO_RUN_ON_COMMIT=off
AGENTS_USAGE_REPORT=on
AGENTS_USAGE_REPORT_TARGET=docs/AI_USAGE_REPORT.md
AGENTS_OPTIMIZATION_REPORT=on
AGENTS_OPTIMIZATION_REPORT_TARGET=docs/AI_OPTIMIZATION_REPORT.md

# Optional tool-specific defaults.
AGENTS_TOKSCALE_CLIENT=codex
AGENTS_TOKSCALE_CLIENTS=codex,cursor,antigravity,claude,gemini,warp
AGENTS_TOKSCALE_PERIOD=today
AGENTS_TOKSCALE_CURSOR_SYNC=on
AGENTS_TOKSCALE_ANTIGRAVITY_SYNC=on
AGENTS_TOKSCALE_WARP_SYNC=on
AGENTS_CONTEXT7_TEST_LIBRARY=/vitejs/vite
AGENTS_CONTEXT7_TEST_QUERY=How to configure the dev server port?

# Optional free-form note for the agent to include in local usage logs.
AGENTS_EXPERIMENT_NOTES=

# Ready-to-use profiles:
#
# Local-only automation:
# AGENTS_CONTEXT7=on
# AGENTS_REPOMIX=on
# AGENTS_TOKSCALE=on
# AGENTS_TOKLESS=ask
# AGENTS_USAGE_REPORT=on
#
# Commit-time automation:
# AGENTS_AUTO_RUN_ON_COMMIT=on
#
# Multi-client tracking:
# AGENTS_TOKSCALE_CLIENTS=codex,cursor,antigravity,claude,gemini,warp
# AGENTS_TOKSCALE_CURSOR_SYNC=on
# AGENTS_TOKSCALE_ANTIGRAVITY_SYNC=on
# AGENTS_TOKSCALE_WARP_SYNC=on
#
# Dashboard publication, validation, or local-only mode:
# AGENTS_TOKSCALE_SUBMIT=on
# AGENTS_TOKSCALE_SUBMIT=dry-run
# AGENTS_TOKSCALE_SUBMIT=off
