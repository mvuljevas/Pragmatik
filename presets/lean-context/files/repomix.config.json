{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown",
    "compress": true,
    "removeComments": false,
    "removeEmptyLines": true,
    "showLineNumbers": true,
    "tokenCountTree": true,
    "tokenBudget": 150000
  },
  "include": [
    "README.md",
    "AGENTS.md",
    "docs/**/*.md",
    "src/**/*",
    "app/**/*",
    "routes/**/*",
    "tests/**/*",
    "manifest.json",
    "package.json",
    "composer.json"
  ],
  "ignore": {
    "customPatterns": [
      "node_modules/**",
      "vendor/**",
      "dist/**",
      "build/**",
      "coverage/**",
      ".cache/**",
      ".env",
      ".env.*",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock",
      "composer.lock",
      "*.log"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
